# ─────────────────────────────────────────────────────────────────────────────
# Scout — Environment Variables
# Copy to .env — docker compose picks it up automatically.
# ─────────────────────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────────────────────
# URL of the web page to capture. The container exits immediately if unset.
CAPTURE_URL=http://myapp:8080

# ── Network ───────────────────────────────────────────────────────────────────
SCOUT_HOST_PORT=8080

# ── Channel metadata (used in M3U and XMLTV output) ───────────────────────────
CHANNEL_ID=scout
CHANNEL_NAME=Scout
CHANNEL_NUMBER=1
# CHANNEL_ICON=http://myserver/icon.png

# ── Capture ───────────────────────────────────────────────────────────────────
# Frame rate in fps. 1 fps is good for slowly-updating pages (dashboards,
# weather displays). Increase for smoother animation.
FRAME_RATE=1

# Puppeteer navigation wait condition for the initial page load.
# Options: load | domcontentloaded | networkidle0 | networkidle2
WAIT_UNTIL=networkidle2

# Optional viewport crop (all four must be set to activate).
# Useful for trimming browser chrome or focusing on a specific region.
# CROP_X=0
# CROP_Y=0
# CROP_WIDTH=1280
# CROP_HEIGHT=720

# ── Encoding ──────────────────────────────────────────────────────────────────
RESOLUTION=1280:720
VIDEO_BITRATE=1000k
AUDIO_BITRATE=128k

# ── HLS tuning ────────────────────────────────────────────────────────────────
HLS_SEG=6       # seconds per .ts segment
HLS_SIZE=10     # segments kept in the live playlist window

# ── Resource limits ───────────────────────────────────────────────────────────
SCOUT_MAX_CPU=1.0
SCOUT_MAX_MEM=1G

# ── Debug ─────────────────────────────────────────────────────────────────────
# DEBUG=1
