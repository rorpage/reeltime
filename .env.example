# ─────────────────────────────────────────────────────────────────────────────
# Reeltime — Environment Variables
# Copy to .env — docker compose picks it up automatically.
# ─────────────────────────────────────────────────────────────────────────────

# ── Resource limits ───────────────────────────────────────────────────────────
MAX_CPU=1.0
MAX_MEM=1G
MIN_CPU=0.25
MIN_MEM=256M

# ── Thread cap ────────────────────────────────────────────────────────────────
# Set equal to MAX_CPU to avoid cgroup throttling (0 = ffmpeg auto-detects).
FFMPEG_THREADS=0

# ── Network ───────────────────────────────────────────────────────────────────
HOST_PORT=8080

# ── HLS tuning ────────────────────────────────────────────────────────────────
HLS_SEG=6       # seconds per .ts segment
HLS_SIZE=10     # segments kept in the live playlist window

# ── Encoding ──────────────────────────────────────────────────────────────────
RESOLUTION=1280:720
VIDEO_BITRATE=2000k
AUDIO_BITRATE=128k
FRAMERATE=30

# ── FIFO writer ───────────────────────────────────────────────────────────────
# For loop_count: -1 (infinite), prefill this many playlist passes per run.
# Higher values reduce rollover frequency. 100 passes is a good default for
# long-running streams.
FOREVER_PASSES=100

# Path of the named FIFO on disk (rarely needs changing).
FIFO_PATH=/tmp/playlist.ffconcat

# ── Debug ─────────────────────────────────────────────────────────────────────
# DEBUG=1
