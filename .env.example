# ─────────────────────────────────────────────────────────────────────────────
# Reeltime — Environment Variables
# Copy to .env — docker compose picks it up automatically.
# ─────────────────────────────────────────────────────────────────────────────

# ── Resource limits ───────────────────────────────────────────────────────────
MAX_CPU=1.0
MAX_MEM=1G
MIN_CPU=0.25
MIN_MEM=256M

# ── Thread cap ────────────────────────────────────────────────────────────────
# Set equal to MAX_CPU to avoid cgroup throttling (0 = ffmpeg auto-detects).
FFMPEG_THREADS=0

# ── Network ───────────────────────────────────────────────────────────────────
HOST_PORT=8080

# ── HLS tuning ────────────────────────────────────────────────────────────────
HLS_SEG=6       # seconds per .ts segment
HLS_SIZE=10     # segments kept in the live playlist window

# ── Encoding ──────────────────────────────────────────────────────────────────
RESOLUTION=1280:720
VIDEO_BITRATE=2000k
AUDIO_BITRATE=128k
FRAMERATE=30

# ── FIFO writer ───────────────────────────────────────────────────────────────
# Write the next entry into the FIFO this many seconds before the current
# clip's outpoint.  Gives ffmpeg time to open the next HTTP source.
# Also determines how far /health "currentVideo" can lead actual playback.
#   • Raise if you see gaps between clips (slow origin servers).
#   • Lower for more accurate health reporting.
#   Minimum recommended: 5 s.  Default: 10 s.
QUEUE_AHEAD_SECS=10

# Path of the named FIFO on disk (rarely needs changing).
FIFO_PATH=/tmp/playlist.ffconcat

# ── Debug ─────────────────────────────────────────────────────────────────────
# DEBUG=1
