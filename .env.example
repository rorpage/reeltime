# ─────────────────────────────────────────────────────────────────────────────
# Reeltime — Environment Variables
# Copy to .env — docker compose picks it up automatically.
# ─────────────────────────────────────────────────────────────────────────────

# ── Resource limits ───────────────────────────────────────────────────────────
MAX_CPU=1.0
MAX_MEM=1G
MIN_CPU=0.25
MIN_MEM=256M

# ── Thread cap ────────────────────────────────────────────────────────────────
# Set equal to MAX_CPU to avoid cgroup throttling (0 = ffmpeg auto-detects).
FFMPEG_THREADS=0

# ── Network ───────────────────────────────────────────────────────────────────
HOST_PORT=8080

# ── HLS tuning ────────────────────────────────────────────────────────────────
HLS_SEG=6       # seconds per .ts segment
HLS_SIZE=10     # segments kept in the live playlist window

# ── Encoding ──────────────────────────────────────────────────────────────────
RESOLUTION=1280:720
VIDEO_BITRATE=2000k
AUDIO_BITRATE=128k
FRAMERATE=30

# ── FIFO writer ───────────────────────────────────────────────────────────────
# For loop_count: -1 (infinite), how many times the full playlist is queued
# per rollover cycle. Keep this low for large playlists — 3 passes of 80×48-min
# videos = ~8 days before rollover. Raise it only for short playlists.
# Rule of thumb: ceil(target_days / (num_videos × avg_duration_hours))
PASSES_PER_CYCLE=3

# Path of the named FIFO on disk (rarely needs changing).
FIFO_PATH=/tmp/playlist.ffconcat

# ── Debug ─────────────────────────────────────────────────────────────────────
# DEBUG=1
