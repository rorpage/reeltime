# Environment
.env
.env.local

# User-specific config files (not committed; copy from *.example.yaml to create)
director.config.yaml

# Generated Docker Compose file (produced by `npm run mark`)
docker-compose.director.yml

# Configuration directory (config files and state files live here)
config/

# Channel configs and state files (created by users, not committed)
channels/

# State files written by the reel (may land next to config files or in state/)
state/
state.*_reeltime.json

# Dependencies
node_modules/

# Logs
npm-debug.log*

# Runtime
/tmp/hls/

# Generated playlist configs from tv-show-query tool
tools/tv-show-query/*.yaml

# OS
.DS_Store
Thumbs.db
