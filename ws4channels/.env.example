# ─────────────────────────────────────────────────────────────────────────────
# WS4Channels — Environment Variables
# Copy to .env — docker compose picks it up automatically.
# ─────────────────────────────────────────────────────────────────────────────

# ── WS4KP connection ──────────────────────────────────────────────────────────
# IP or hostname of the machine running the WS4KP container.
WS4KP_HOST=192.168.1.100
WS4KP_PORT=8080

# Your ZIP code (or city/state) for the weather location.
ZIP_CODE=63101

# ── Network ───────────────────────────────────────────────────────────────────
HOST_PORT=9798

# ── Channel metadata (used in M3U and XMLTV output) ───────────────────────────
CHANNEL_ID=weatherstar4000
CHANNEL_NAME=WeatherStar 4000
CHANNEL_NUMBER=275
# CHANNEL_ICON=http://myserver/logo/ws4000.png

# ── Encoding ──────────────────────────────────────────────────────────────────
RESOLUTION=1280:720
VIDEO_BITRATE=1000k
AUDIO_BITRATE=128k
FRAME_RATE=10

# ── HLS tuning ────────────────────────────────────────────────────────────────
HLS_SEG=2       # seconds per .ts segment
HLS_SIZE=5      # segments kept in the live playlist window

# ── Screenshot crop ───────────────────────────────────────────────────────────
# Trims browser chrome and captures the 16:9 weather content area.
# Requires WS4KP running with WSQS_settings_wide_checkbox=true.
# CROP_X=4
# CROP_Y=50
# CROP_WIDTH=840
# CROP_HEIGHT=470

# ── Music ─────────────────────────────────────────────────────────────────────
# Mount a directory of MP3 files to /music inside the container.
# Leave empty for silent audio.
MUSIC_VOLUME=0.5
SHUFFLE_MUSIC=false

# ── Resource limits ───────────────────────────────────────────────────────────
MAX_CPU=1.0
MAX_MEM=1096M
