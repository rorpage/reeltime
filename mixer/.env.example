# ─────────────────────────────────────────────────────────────────────────────
# Mixer - Environment Variables
# Copy to .env - docker compose picks it up automatically.
# ─────────────────────────────────────────────────────────────────────────────

# ── Music ─────────────────────────────────────────────────────────────────────
# Mount a directory of MP3 files to /music inside the container.
MUSIC_DIR=/music
SHUFFLE_MUSIC=false

# ── Audio source ──────────────────────────────────────────────────────────────
# mp3   - play MP3 files from MUSIC_DIR (default)
# http  - pull from an HTTP audio stream URL (set AUDIO_URL too)
# silent - no audio
AUDIO_SOURCE=mp3
# AUDIO_URL=http://icecast.example.com/stream
AUDIO_VOLUME=1.0

# ── Channel metadata (used in M3U and XMLTV output) ───────────────────────────
CHANNEL_ID=mixer
CHANNEL_NAME=Mixer
CHANNEL_NUMBER=1
# CHANNEL_ICON=http://myserver/logo/mixer.png

# ── Network ───────────────────────────────────────────────────────────────────
HOST_PORT=8080

# ── Encoding ──────────────────────────────────────────────────────────────────
RESOLUTION=1280:720
VIDEO_BITRATE=200k
AUDIO_BITRATE=128k

# ── Background ────────────────────────────────────────────────────────────────
# Solid color background (hex, e.g. 0x1a1a2e). Used when BG_IMAGE is not set.
BG_COLOR=0x000000
# Mount an image file and set the path here to use it as the background.
# BG_IMAGE=/bg/cover.jpg

# ── HLS tuning ────────────────────────────────────────────────────────────────
HLS_SEG=6       # seconds per .ts segment
HLS_SIZE=10     # segments kept in the live playlist window
FRAME_RATE=1    # frames per second (1 is fine for a static background)
